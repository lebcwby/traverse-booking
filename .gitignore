# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files — ignore every variant by default; .env.example is the
# only file with placeholder values that's safe to commit. Belt-and-suspenders
# against `git add -A` accidentally staging a real secret file. Previously
# this list only covered .env*.local + a few specific names (.env.verify,
# .env.vercel) — but new variants like .env.local.new / .env.local.tmp
# slipped through. The `.env*` glob catches all of them.
.env*
!.env.example

# vercel
.vercel

# claude code
.claude/.mcp.json

# typescript
*.tsbuildinfo
next-env.d.ts
.gstack/

# local tool state
supabase/.temp/
.context/
scripts/.*.json

# local-only artifacts (audit reports, email drafts)
cro-audit-*.html
cro-audit-*.pdf
email-templates/
HANDOFF_EMAIL.md
