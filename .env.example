# =============================================================================
# stay-portland — Guest booking portal
# Copy to .env.local and fill in values. Or run: vercel env pull .env.local
# =============================================================================

# Supabase (your own project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
DATABASE_URL=

# Optional: dashboard DB used to enrich alerts (YoY rate compare, nicknames).
# Leave blank to disable enrichment — alerts still send without it.
DASHBOARD_SUPABASE_URL=
DASHBOARD_SUPABASE_ANON_KEY=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Guesty BEAPI (booking engine)
GUESTY_BEAPI_CLIENT_ID=
GUESTY_BEAPI_CLIENT_SECRET=
GUESTY_BEAPI_BACKUP_CLIENT_ID=
GUESTY_BEAPI_BACKUP_CLIENT_SECRET=

# Guesty API (internal — NEVER request new tokens, use cached only)
GUESTY_CLIENT_ID=
GUESTY_CLIENT_SECRET=

# Google Maps & Mapbox
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
NEXT_PUBLIC_MAPBOX_TOKEN=

# Google Analytics / GTM / Ads
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=
GA4_MP_API_SECRET=
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GOOGLE_ADS_CHECKOUT_LABEL=
NEXT_PUBLIC_GOOGLE_ADS_PURCHASE_LABEL=
NEXT_PUBLIC_GOOGLE_ADS_PURCHASE_MODE=client
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_PURCHASE_CONVERSION_ACTION_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_SERVICE_ACCOUNT_EMAIL=
GOOGLE_ADS_SERVICE_ACCOUNT_PRIVATE_KEY=

# Google Service Account (for GA4 Measurement Protocol, etc.)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Meta / Facebook
NEXT_PUBLIC_META_PIXEL_ID=
META_PIXEL_ID=
META_CAPI_TOKEN=
META_TEST_EVENT_CODE=

# Klaviyo (email marketing)
KLAVIYO_PRIVATE_KEY=

# Resend (transactional email)
RESEND_API_KEY=
GMAIL_USER_EMAIL=

# Where booking + system alerts are sent
ALERT_TO_EMAIL=
ALERT_FROM_EMAIL=Booking Alerts <noreply@yourdomain.com>

# "List your property" inquiry recipients (comma-separated)
LISTING_INQUIRY_RECIPIENTS=
LISTING_INQUIRY_FROM=Inquiries <noreply@yourdomain.com>

# Wheelhouse (revenue management)
WHEELHOUSE_RM_API_KEY=

# Cron job verification
CRON_SECRET=

# Checkout lookup webhook
PENDING_CHECKOUT_LOOKUP_SECRET=

# Sentry (auto-provisioned by Vercel Marketplace — no manual setup needed)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
