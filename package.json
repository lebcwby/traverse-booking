{
  "name": "book-traverse",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' next dev --webpack",
    "dev:turbo": "node scripts/dev-turbopack.mjs",
    "dev:turbo:clean": "TURBOPACK_CACHE_GUARD_FORCE_CLEAR=1 node scripts/dev-turbopack.mjs",
    "dev:webpack": "NODE_OPTIONS='--max-old-space-size=4096' next dev --webpack",
    "prebuild": "node scripts/verify-public-html-tracking.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "seed-pois": "tsx --env-file=.env.local scripts/seed-pois.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.68",
    "@ai-sdk/react": "^3.0.156",
    "@anthropic-ai/sdk": "^0.85.0",
    "@googlemaps/js-api-loader": "^1.16.10",
    "@guestyorg/tokenization-js": "^1.1.1",
    "@sentry/nextjs": "^10.45.0",
    "@sparticuz/chromium-min": "^143.0.4",
    "@stripe/react-stripe-js": "^5.6.0",
    "@stripe/stripe-js": "^8.7.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "ai": "^6.0.154",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.1",
    "date-fns": "^4.1.0",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.577.0",
    "mapbox-gl": "^3.18.1",
    "next": "^16.1.6",
    "pg": "^8.19.0",
    "puppeteer-core": "^24.40.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.3",
    "resend": "^6.9.2",
    "sanitize-html": "^2.17.1",
    "stripe": "^20.3.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/eslint-plugin-next": "^16.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^22",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "eslint": "^9",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5.7",
    "vitest": "^4.0.18"
  }
}
